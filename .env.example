# ==========================================
# Application
# ==========================================
ENVIRONMENT=development
DEBUG=true

APP_NAME=My Stuff API
APP_VERSION=1.0.0

SECRET_KEY=change_me

DEMO_MODE=true

# ==========================================
# Database
# ==========================================

DATABASE_URL=sqlite:///./mystuff.db

# ==========================================
# Uploads
# ==========================================

UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=500

# ==========================================
# Storage
# ==========================================

STORAGE_PROVIDER=local

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_REGION=auto
S3_CUSTOM_DOMAIN=

# ==========================================
# Hugging Face
# ==========================================

HF_TOKEN=

# ==========================================
# Email
# ==========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@mystuff.app